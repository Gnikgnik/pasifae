  "stanze": {
    "ingresso": {
      "nome": "Ingresso della caverna",
      "desc": "Una fenditura nella roccia si apre verso nord, nel buio. La luce del giorno arriva fin qui ma non oltre.",
      "uscite": {
        "nord": "corridoio"
      },
      "buia": false
    },
    "corridoio": {
      "nome": "Corridoio buio",
      "desc": "Un angusto corridoio scavato nella pietra. Nel muro a destra noti una stretta fessura metallica. Una botola nel pavimento conduce verso il basso.",
      "uscite": {
        "sud": "ingresso",
        "giu": {
          "to": "tesoro",
          "se": "porta_aperta",
          "bloccata": "La botola e' sprangata. Deve esserci un meccanismo per aprirla."
        }
      },
      "buia": true
    },
    "tesoro": {
      "nome": "Camera del tesoro",
      "desc": "Una piccola camera scintillante. Al centro, su un piedistallo, riposa un antico calice d'oro. A ovest, una porticina è sbarrata da un lucchetto.",
      "uscite": {
        "su": "corridoio",
        "ovest": {
          "to": "cripta",
          "se": "lucchetto_aperto",
          "bloccata": "La porticina è chiusa da un robusto lucchetto."
        }
      },
      "buia": true
    },
    "cripta": {
      "nome": "Cripta dimenticata",
      "desc": "Una nicchia silenziosa, coperta di polvere. Su una mensola di pietra brilla un diadema.",
      "uscite": {
        "est": "tesoro"
      },
      "buia": true
    }
  },
